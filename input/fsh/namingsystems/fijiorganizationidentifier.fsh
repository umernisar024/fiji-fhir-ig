Instance: FijiOrganizationIdentifier
InstanceOf: NamingSystem
Usage: #definition
Title: "Fiji Organization Identifier"
Description: "NamingSystem for organization identifiers in Fiji, using a simulated national identifier system for demonstration purposes."
* name = "FijiOrganizationIdentifier"
* status = #active
* kind = #identifier
* date = "2026-03-31"
* uniqueId[0].type = #uri
* uniqueId[0].value = "http://fhir.health.gov.fj/identifier/facility"
* uniqueId[0].preferred = true