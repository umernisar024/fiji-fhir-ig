Instance: FijiPatientIdentifier
InstanceOf: NamingSystem
Usage: #definition
Title: "Fiji Patient Identifier"
Description: "NamingSystem for patient identifiers in Fiji, using a simulated national identifier system for demonstration purposes."
* name = "FijiPatientIdentifier"
* status = #active
* kind = #identifier
* date = "2026-03-31"
* uniqueId[0].type = #uri
* uniqueId[0].value = "http://fhir.health.gov.fj/identifier/nhi"
* uniqueId[0].preferred = true