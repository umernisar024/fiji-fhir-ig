Instance: PacificAddressExampleFiji
InstanceOf: PacificAddress
Usage: #inline

* text = "Opposite Methodist Church, Nabouwalu Village, Bua Province, Fiji"
* line[0] = "Opposite Methodist Church"
* district = "Bua"
* state = "Northern Division"
* country = "FJ"

* extension[village].valueString = "Nabouwalu"
* extension[island].valueString = "Vanua Levu"

* extension[geolocation].extension[latitude].valueDecimal = -16.804
* extension[geolocation].extension[longitude].valueDecimal = 178.746